{
  "name": "infinibay",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -H ::",
    "build": "next build --webpack",
    "start": "next start -H ::",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:check": "graphql-codegen --config codegen.ts --check",
    "codegen:validate": "graphql-codegen --config codegen.ts --validate",
    "codegen:clean": "rm -f src/gql/hooks.ts src/gql/graphql.ts src/gql/gql.ts",
    "graphql:lint": "graphql-eslint --config .graphql-eslintrc.yml src/gql/**/*.graphql",
    "ci:codegen": "npm run codegen:check && npm run codegen:validate",
    "build:check-codegen": "npm run codegen:check && npm run build",
    "postinstall": "husky install",
    "prepare": "husky install",
    "validate:spacing": "node scripts/validate-spacing.js",
    "validate:all": "npm run validate:spacing && npm run lint"
  },
  "dependencies": {
    "@apollo/client": "^4.1.7",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@infinibay/harbor": "file:../harbor",
    "@monaco-editor/react": "^4.6.0",
    "@reduxjs/toolkit": "^2.3.0",
    "@types/react": "^19.2.14",
    "apexcharts": "^5.10.6",
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "connect-timeout": "^1.9.0",
    "date-fns": "^4.1.0",
    "framer-motion": "*",
    "graphql": "^16.9.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^1.8.0",
    "monaco-yaml": "^5.1.1",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-apexcharts": "^2.1.0",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.53.1",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.6.0",
    "react-redux": "^9.1.2",
    "recharts": "^3.1.2",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/client-preset": "^5.3.0",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-operations": "^5.1.0",
    "@graphql-codegen/typescript-react-apollo": "^4.3.2",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.32",
    "postcss-loader": "^8.1.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "src/gql/**/*.graphql": [
      "npm run codegen:validate"
    ]
  },
  "overrides": {
    "dompurify": "^3.4.0"
  }
}
